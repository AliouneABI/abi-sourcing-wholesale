{
  "buildCommand": "pnpm build",
  "outputDirectory": "dist/public",
  "installCommand": "pnpm install",
  "framework": "vite",
  "env": {
    "VITE_FORMSPREE_ID": "@vite_formspree_id",
    "VITE_WHATSAPP_NUMBER": "@vite_whatsapp_number"
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
